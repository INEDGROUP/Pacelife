	<string>PaceLife reads your steps and sleep data to calculate your daily energy score</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>PaceLife saves your activity data to improve your recommendations</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>PaceLife uses your location to track your active routes</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>PaceLife uses your location to build personalised routes around you</string>
